                            <attDef ident="when-custom" mode="delete"/>
                            <attDef ident="when-iso" mode="delete"/>
                            
                            
                            
                            
                            <attDef ident="type" mode="change" usage="req">
                                <desc>Characeterisiert den Namen als historisch ("hist"), biblisch ("bibl"),
                                    mythologisch ("Mythos") oder undefiniert/unbekannt.</desc>
                                <valList type="closed" mode="replace">
                                    <valItem ident="hist">
                                        <desc>Name einer historischen Person</desc>
                                    </valItem>
                                    <valItem ident="bibl">
                                        <desc>Name einer biblischen Person</desc>
                                    </valItem>
                                    <valItem ident="undefined">
                                        <desc>Name nicht kategorisierten Person</desc>
                                    </valItem>
                                    <valItem ident="myth">
                                        <desc>Name einer mythologischen Person</desc>
                                    </valItem>
                                    <valItem ident="main">
                                        <desc>Hauptansetzung eines Personennamens im Personenregiser</desc>
                                    </valItem>
                                    <valItem ident="variation">
                                        <desc>Nebenansetzung eines Personennamens im Personenregiser</desc>
                                    </valItem>
                                    <valItem ident="reg">
                                        <desc>Normalisierte Ansetzung eines Personennamens im Personenregiser</desc>
                                    </valItem>
                                </valList>
                            </attDef>
                        </attList>
                    </elementSpec>
                    <elementSpec ident="placeName" module="namesdates" mode="change">
                        <constraintSpec ident="subtype-on-placeName-in-editions" mode="add" scheme="schematron">
                            <constraint>
                                <s:rule context="tei:placeName[@type='main'][ancestor::tei:text/@type='corpusIndex']">
                                    <s:assert test="exists(@key)">@key ist verpflichtend auf der Hauptansetzung des Ortsnamens im Ortsregister</s:assert>
                                </s:rule>
                                <s:rule context="tei:placeName[ancestor::tei:text/@type='book']">
                                    <s:assert test="exists(@subtype)">@subtype ist verpflichtend auf placeName in editierten Texten</s:assert>
                                    <s:assert test="exists(@key)">@key ist verpflichtend auf placeName in editierten Texten</s:assert>
                                </s:rule>
                            </constraint>
                        </constraintSpec>
                        <constraintSpec ident="placeName-index-consistency" mode="add" scheme="schematron">
                            <constraint>
                                <s:rule context="tei:placeName[ancestor::tei:text/@type='book'][@key]">
                                    <s:let name="pathToPlaceIndex" value="'../index/output/abacus-index_placenames.xml'"/>
                                    <s:let name="placeIndex" value="doc($pathToPlaceIndex)"/>
                                    <s:let name="placeNameTypes" value="$placeIndex//tei:listPlace/@type"/>
                                    <s:let name="instanceKey" value="@key"/>
                                    <s:let name="placeEntry" value="$placeIndex//tei:placeName[@type='main'][@key= $instanceKey]"/>
                                    <s:let name="instanceType" value="@type"/>
                                    <s:let name="placeEntryCategory" value="$placeEntry/ancestor::tei:listPlace/@type"/>
                                    <s:report test="count($placeNameTypes) eq 0">Fehler beim Generieren der Liste von placeName/@type aus <s:value-of select="$pathToPlaceIndex"/></s:report>
                                    <s:assert test="@type = $placeNameTypes">placeName/@type muss einer der folgenden sein: <s:value-of select="string-join($placeNameTypes,',')"/></s:assert>
                                    <s:assert test="exists($placeEntry)">Eintrag im Ortsregister konnte nicht anhand @key <s:value-of select="instanceKey"/> identifiziert werden.</s:assert>
                                    <s:assert test="$instanceType = $placeEntryCategory">placeName/@type (<s:value-of select="$instanceType"/>) entspricht nicht listPlace/@type des Registereintrags (<s:value-of select="$placeEntryCategory"/>)</s:assert>
                                </s:rule>
                            </constraint>
                        </constraintSpec>
