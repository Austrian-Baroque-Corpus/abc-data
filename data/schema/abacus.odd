                            <attDef ident="synch" mode="delete"/>
                            <attDef ident="type" mode="delete"/>
                            
                            
                            
                            
                            <attDef ident="ref" mode="change" usage="req">
                                <valList type="closed" mode="replace">
                                    <valItem ident="#tironian-et">
                                        <desc>repräsentiert ein tironisches Et (Unicode-Zeichen U+204A, 'TIRONIAN SIGN ET')</desc>
                                    </valItem>
                                    <valItem ident="#footerDots"/>
                                    <valItem ident="#bracketsGM"/>
                                    <valItem ident="#bracketsMW"/>
                                    <valItem ident="#bracketsTC"/>
                                </valList>
                            </attDef>
                        </attList>
                    </elementSpec>
                    
                    <elementSpec ident="persName" module="namesdates" mode="change">
                        <constraintSpec ident="persName-index-consistency" mode="add" scheme="schematron">
                            <constraint>
                                <s:rule context="tei:persName[ancestor::tei:text/@type='book'][@key]">
                                    <s:let name="pathToPersonIndex" value="'../index/output/abacus-index_persnames.xml'"/>
                                    <s:let name="personIndex" value="doc($pathToPersonIndex)"/>
                                    <s:let name="persNameTypes" value="$personIndex//tei:listPerson/@type"/>
                                    <s:let name="instanceKey" value="@key"/>
                                    <s:let name="personEntry" value="$personIndex//tei:persName[@type='main'][@key= $instanceKey]"/>
                                    <s:let name="instanceType" value="@type"/>
                                    <s:let name="personEntryCategory" value="$personEntry/ancestor::tei:listPerson/@type"/>
                                    <s:report test="count($persNameTypes) eq 0">Fehler beim Generieren der Liste von personName/@type aus <s:value-of select="$pathToPersonIndex"/></s:report>
                                    <s:assert test="@type = $persNameTypes">persName/@type muss einer der folgenden sein: <s:value-of select="string-join($persNameTypes,',')"/></s:assert>
                                    <s:assert test="exists($personEntry)">Eintrag im Personeregister konnte nicht anhand @key <s:value-of select="instanceKey"/> identifiziert werden.</s:assert>
                                    <s:assert test="$instanceType = $personEntryCategory">persName/@type (<s:value-of select="$instanceType"/>) entspricht nicht listPerson/@type des Registereintrags (<s:value-of select="$personEntryCategory"/>)</s:assert>
                                </s:rule>
                            </constraint>
                        </constraintSpec>
                        <attList>
                            <attDef ident="ana" mode="delete"/>
                            <attDef ident="atLeast" mode="delete"/>
                            <attDef ident="atMost" mode="delete"/>
                            <attDef ident="calendar" mode="delete"/>
